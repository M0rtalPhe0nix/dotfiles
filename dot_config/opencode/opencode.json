{
  "$schema": "https://opencode.ai/config.json",
  "share": "manual",
  "autoupdate": false,
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "~/.aws/**": "deny",
      "~/.ssh/**": "deny",
      "~/.config/zsh/secrets.zsh": "deny"
    },
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git push --force*": "ask",
      "rm -rf *": "ask",
      "sudo *": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/Documents/**": "allow"
    },
    "webfetch": "allow",
    "task": "allow"
  }
}
