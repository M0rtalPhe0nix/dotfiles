{
  "$schema": "https://opencode.ai/config.json",
  "share": "manual",
  "autoupdate": false,
  "lsp": {
    "pyright": {
      "command": ["pyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts"]
    },
    "marksman": {
      "command": ["marksman", "server"],
      "extensions": [".md", ".markdown"]
    },
    "terraform": {
      "command": ["terraform-ls", "serve"],
      "extensions": [".tf", ".tfvars", ".hcl"]
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "~/.aws/**": "deny",
      "~/.ssh/**": "deny",
      "~/.config/zsh/secrets.zsh": "deny"
    },
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git push --force*": "ask",
      "rm -rf *": "ask",
      "sudo *": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/Documents/**": "allow"
    },
    "webfetch": "allow",
    "task": "allow"
  }
}
