[init]
	defaultBranch = main
[core]
	pager = delta
	excludesFile = ~/.config/git/ignore
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
[merge]
	conflictStyle = zdiff3
[pull]
	rebase = true
[fetch]
	prune = true
[push]
	autoSetupRemote = true
