{{- $infraTool := "none" -}}
{{- if hasKey . "infraTool" -}}
{{-   $infraTool = .infraTool -}}
{{- end -}}
{{- $useCorporateCA := false -}}
{{- if hasKey . "useCorporateCA" -}}
{{-   $useCorporateCA = .useCorporateCA -}}
{{- end -}}
{{- $installPythonLsp := false -}}
{{- if hasKey . "installPythonLsp" -}}
{{-   $installPythonLsp = .installPythonLsp -}}
{{- end -}}
{{- $installTypeScriptLsp := false -}}
{{- if hasKey . "installTypeScriptLsp" -}}
{{-   $installTypeScriptLsp = .installTypeScriptLsp -}}
{{- end -}}
{{- $installMarkdownLsp := false -}}
{{- if hasKey . "installMarkdownLsp" -}}
{{-   $installMarkdownLsp = .installMarkdownLsp -}}
{{- end -}}
{{- $installTerraformLsp := false -}}
{{- if hasKey . "installTerraformLsp" -}}
{{-   $installTerraformLsp = .installTerraformLsp -}}
{{- end -}}
#!/bin/sh
set -eu

source_dir="$(chezmoi source-path)"
state="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles"

{{ if ne .chezmoi.os "darwin" -}}
update_ghostty() {
	if ! grep -Eq '^ID=(ubuntu|debian)$' /etc/os-release; then
		printf '%s\n' "Ghostty updates are unavailable on this Debian release." >&2
		return 1
	fi
	ghostty_installer="$(mktemp)"
	if ! curl -fsSL https://raw.githubusercontent.com/mkasberg/ghostty-ubuntu/HEAD/install.sh -o "$ghostty_installer"; then
		rm -f "$ghostty_installer"
		return 1
	fi
	if ! bash "$ghostty_installer"; then
		rm -f "$ghostty_installer"
		return 1
	fi
	rm -f "$ghostty_installer"
}
{{ end -}}

usage() {
	printf '%s\n' "usage: dotfiles {apply|diff|doctor|extensions|preferences|update|rollback}"
}

doctor() {
	failed=0
	for command in brew chezmoi mise gh rg fd fzf bat eza jq yq dust btm zoxide delta tldr shellcheck shfmt starship zsh pnpm ruff uv; do
		if command -v "$command" >/dev/null 2>&1; then
			printf 'ok   %s\n' "$command"
		else
			printf 'FAIL %s is missing\n' "$command"
			failed=1
		fi
	done
	{{ if eq $infraTool "terraform" -}}
	command -v terraform >/dev/null 2>&1 || {
		printf '%s\n' "FAIL terraform 1.5.7 is missing"
		failed=1
	}
	{{ else if eq $infraTool "opentofu" -}}
	command -v tofu >/dev/null 2>&1 || {
		printf '%s\n' "FAIL OpenTofu is missing"
		failed=1
	}
	{{ end -}}
	{{ if $installPythonLsp -}}
	command -v pyright-langserver >/dev/null 2>&1 || {
		printf '%s\n' "FAIL Python language server is missing"
		failed=1
	}
	{{ end -}}
	{{ if $installTypeScriptLsp -}}
	command -v typescript-language-server >/dev/null 2>&1 || {
		printf '%s\n' "FAIL TypeScript language server is missing"
		failed=1
	}
	{{ end -}}
	{{ if $installMarkdownLsp -}}
	command -v marksman >/dev/null 2>&1 || {
		printf '%s\n' "FAIL Markdown language server is missing"
		failed=1
	}
	{{ end -}}
	{{ if $installTerraformLsp -}}
	command -v terraform-ls >/dev/null 2>&1 || {
		printf '%s\n' "FAIL Terraform language server is missing"
		failed=1
	}
	{{ end -}}
	if ! command -v code >/dev/null 2>&1; then
		printf '%s\n' "FAIL VS Code is missing"
		failed=1
	fi
	{{ if $useCorporateCA -}}
	corporate_ca="${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles/corporate-ca.pem"
	ca_bundle="${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles/ca-bundle.pem"
	if [ ! -r "$corporate_ca" ] || [ ! -r "$ca_bundle" ] || ! openssl x509 -in "$corporate_ca" -noout >/dev/null 2>&1; then
		printf '%s\n' "FAIL corporate CA trust files are missing or invalid"
		failed=1
	fi
	{{ end -}}
	{{ if eq .chezmoi.os "darwin" -}}
	if [ ! -d /Applications/Ghostty.app ] && [ ! -d "$HOME/Applications/Ghostty.app" ]; then
		printf '%s\n' "FAIL Ghostty is missing"
		failed=1
	fi
	{{ else -}}
	command -v ghostty >/dev/null 2>&1 || {
		printf '%s\n' "FAIL Ghostty is missing"
		failed=1
	}
	{{ end -}}
	gh auth status >/dev/null 2>&1 || {
		printf '%s\n' "FAIL GitHub authentication"
		failed=1
	}
	{{ if .installClaude -}}
	if command -v claude >/dev/null 2>&1; then
		claude auth status >/dev/null 2>&1 || {
			printf '%s\n' "FAIL Claude authentication"
			failed=1
		}
	else
		printf '%s\n' "FAIL Claude Code is missing"
		failed=1
	fi
	{{ end -}}
	if command -v opencode >/dev/null 2>&1; then
		opencode auth list 2>/dev/null | grep -q . || {
			printf '%s\n' "FAIL OpenCode authentication"
			failed=1
		}
	else
		printf '%s\n' "FAIL OpenCode is missing"
		failed=1
	fi
	if [ ! -r "$HOME/.config/zsh/secrets.zsh" ] || [ "$(stat -f %Lp "$HOME/.config/zsh/secrets.zsh" 2>/dev/null || stat -c %a "$HOME/.config/zsh/secrets.zsh" 2>/dev/null || true)" != 600 ]; then
		printf '%s\n' "FAIL ~/.config/zsh/secrets.zsh must have mode 0600"
		failed=1
	fi
	{{ if eq .chezmoi.os "darwin" -}}
	system_profiler SPFontsDataType 2>/dev/null | grep -qi 'MesloLGS Nerd Font' || {
		printf '%s\n' "FAIL Meslo Nerd Font is not visible"
		failed=1
	}
	{{ else -}}
	fc-list 2>/dev/null | grep -qi 'MesloLGS Nerd Font' || {
		printf '%s\n' "FAIL Meslo Nerd Font is not visible"
		failed=1
	}
	{{ end -}}
	zsh -lic exit || {
		printf '%s\n' "FAIL interactive Zsh startup"
		failed=1
	}
	chezmoi verify --exclude=scripts || {
		printf '%s\n' "FAIL managed files differ"
		failed=1
	}
	return "$failed"
}

update() {
	chezmoi update --apply=false
	brew update
	for package in $(brew bundle list --formula --file "$source_dir/Brewfile"); do
		brew upgrade "$package" 2>/dev/null || true
	done
	{{ if eq .chezmoi.os "darwin" -}}
	for package in $(brew bundle list --cask --file "$source_dir/Brewfile"); do
		brew upgrade --cask "$package" 2>/dev/null || true
	done
	{{ else -}}
	sudo apt-get install --only-upgrade -y code
	update_ghostty
	{{ end -}}
	mise upgrade --yes
	zim_home="${ZIM_HOME:-$HOME/.zim}"
	ZIM_HOME="$zim_home" zsh "$zim_home/zimfw.zsh" update
	ZIM_HOME="$zim_home" zsh "$zim_home/zimfw.zsh" install
	if command -v code >/dev/null 2>&1; then
		while IFS= read -r extension; do
			extension="$(printf '%s\n' "$extension" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
			[ -n "$extension" ] && code --install-extension "$extension" --force
		done <"$source_dir/extensions.txt"
	fi
	chezmoi apply
}

save_extensions() {
	mode="merge"
	case "${1:-}" in
	"") ;;
	--overwrite) mode="overwrite" ;;
	*)
		usage >&2
		return 2
		;;
	esac

	if ! command -v code >/dev/null 2>&1; then
		printf '%s\n' "VS Code command-line launcher is missing." >&2
		return 1
	fi

	extensions_file="$source_dir/extensions.txt"
	extensions_dir="$(dirname "$extensions_file")"
	installed="$(mktemp)"
	output=""
	cleanup_extensions() {
		rm -f "$installed" "$output"
	}
	trap cleanup_extensions EXIT INT TERM
	output="$(mktemp "$extensions_dir/.extensions.txt.XXXXXX")"

	if ! code --list-extensions >"$installed"; then
		printf '%s\n' "Unable to list installed VS Code extensions." >&2
		return 1
	fi

	if [ "$mode" = "merge" ]; then
		{
			[ ! -f "$extensions_file" ] || cat "$extensions_file"
			cat "$installed"
		} | sed 's/^[[:space:]]*//; s/[[:space:]]*$//' | sed '/^$/d' | LC_ALL=C sort -u >"$output"
	else
		sed 's/^[[:space:]]*//; s/[[:space:]]*$//' "$installed" | sed '/^$/d' | LC_ALL=C sort -u >"$output"
	fi

	mv -f "$output" "$extensions_file"
	printf '%s\n' "Saved VS Code extensions to $extensions_file"
}

preferences() {
	if [ "$(uname -s)" != "Darwin" ]; then
		printf '%s\n' "macOS preferences are only available on Darwin." >&2
		return 1
	fi

	printf '%s\n' "This changes macOS text substitutions, Finder visibility, and keyboard repeat settings."
	printf '%s' "Apply these preferences? [y/N] "
	IFS= read -r confirmation || return 1
	case "$confirmation" in
	y | Y | yes | YES) ;;
	*)
		printf '%s\n' "No macOS preferences were changed."
		return 0
		;;
	esac

	defaults write -g NSAutomaticCapitalizationEnabled -bool false
	defaults write -g NSAutomaticDashSubstitutionEnabled -bool false
	defaults write -g NSAutomaticPeriodSubstitutionEnabled -bool false
	defaults write -g NSAutomaticQuoteSubstitutionEnabled -bool false
	defaults write -g NSAutomaticSpellingCorrectionEnabled -bool false
	defaults write com.apple.finder AppleShowAllExtensions -bool true
	defaults write com.apple.finder ShowPathbar -bool true
	defaults write com.apple.finder ShowStatusBar -bool true
	defaults write -g InitialKeyRepeat -int 15
	defaults write -g KeyRepeat -int 2
	printf '%s\n' "macOS preferences applied. Relaunch Finder to see its updated visibility settings."
}

rollback() {
	backup="$state/pre-bootstrap/latest"
	if [ ! -d "$backup" ]; then
		printf '%s\n' "No pre-bootstrap backup is available." >&2
		exit 1
	fi
	while IFS= read -r target; do
		case "$target" in
		"" | /* | *..*)
			printf '%s\n' "Unsafe backup target: $target" >&2
			exit 1
			;;
		esac
		rm -rf -- "${HOME:?}/$target"
	done <"$backup/targets"
	tar -C "$HOME" -xpf "$backup/files.tar"
	printf '%s\n' "Restored configuration from $backup; installed packages were retained."
}

case "${1:-}" in
apply) chezmoi apply ;;
diff) chezmoi diff ;;
doctor) doctor ;;
extensions)
	shift
	save_extensions "$@"
	;;
preferences) preferences ;;
update) update ;;
rollback) rollback ;;
*)
	usage
	exit 2
	;;
esac
