#!/bin/sh
set -eu

profiles_dir="${XDG_CONFIG_HOME:-$HOME/.config}/git/github-profiles"

usage() {
	printf '%s\n' "usage: github-profile {add <profile> <github-user> <email> [<git-name>]|use <profile>|current|list}"
}

valid_profile() {
	case "$1" in
	"" | *[!A-Za-z0-9-]*) return 1 ;;
	esac
}

require_repository() {
	git rev-parse --git-dir >/dev/null 2>&1 || {
		printf '%s\n' "This command must be run inside a Git repository." >&2
		exit 1
	}
}

case "${1:-}" in
add)
	profile="${2:-}"
	valid_profile "$profile" || {
		printf '%s\n' "Profile names may contain only letters, numbers, and hyphens." >&2
		exit 2
	}
	github_user="${3:-}"
	email="${4:-}"
	name="${5:-$github_user}"
	valid_profile "$github_user" || {
		printf '%s\n' "The GitHub user may contain only letters, numbers, and hyphens." >&2
		exit 2
	}
	[ -n "$email" ] || {
		usage >&2
		exit 2
	}
	if ! gh auth token --hostname github.com --user "$github_user" >/dev/null 2>&1; then
		printf 'Authenticate the GitHub account %s.\n' "$github_user"
		gh auth login --hostname github.com
		gh auth token --hostname github.com --user "$github_user" >/dev/null 2>&1 || {
			printf 'GitHub account %s is not authenticated.\n' "$github_user" >&2
			exit 1
		}
	fi
	[ -n "$name" ] && [ -n "$email" ] || {
		printf '%s\n' "Git author name and email cannot be empty." >&2
		exit 1
	}
	mkdir -p "$profiles_dir"
	chmod 700 "$profiles_dir"
	profile_file="$profiles_dir/$profile.gitconfig"
	git config --file "$profile_file" user.name "$name"
	git config --file "$profile_file" user.email "$email"
	git config --file "$profile_file" github.user "$github_user"
	chmod 600 "$profile_file"
	printf 'Added GitHub profile %s. Run github-profile use %s inside a repository.\n' "$profile" "$profile"
	;;
use)
	profile="${2:-}"
	valid_profile "$profile" || {
		usage >&2
		exit 2
	}
	require_repository
	profile_file="$profiles_dir/$profile.gitconfig"
	[ -f "$profile_file" ] || {
		printf 'Unknown profile %s. Add it with github-profile add %s.\n' "$profile" "$profile" >&2
		exit 1
	}
	name="$(git config --file "$profile_file" --get user.name)"
	email="$(git config --file "$profile_file" --get user.email)"
	github_user="$(git config --file "$profile_file" --get github.user)"
	git config --local user.name "$name"
	git config --local user.email "$email"
	git config --local github.profile "$profile"
	git config --local github.user "$github_user"
	git config --local credential.https://github.com.username "$github_user"
	git config --local --unset-all credential.https://github.com.helper 2>/dev/null || true
	git config --local --add credential.https://github.com.helper ""
	git config --local --add credential.https://github.com.helper gh-profile
	printf 'Using GitHub profile %s in %s.\n' "$profile" "$(git rev-parse --show-toplevel)"
	;;
current)
	require_repository
	profile="$(git config --local --get github.profile 2>/dev/null || true)"
	[ -n "$profile" ] || {
		printf '%s\n' "No GitHub profile is selected for this repository." >&2
		exit 1
	}
	printf '%s\n' "$profile"
	;;
list)
	current_profile="$(git config --local --get github.profile 2>/dev/null || true)"
	if [ -d "$profiles_dir" ]; then
		for profile_file in "$profiles_dir"/*.gitconfig; do
			[ -e "$profile_file" ] || continue
			profile="$(basename "$profile_file" .gitconfig)"
			if [ "$profile" = "$current_profile" ]; then
				printf '* %s\n' "$profile"
			else
				printf '  %s\n' "$profile"
			fi
		done
	fi
	;;
*)
	usage >&2
	exit 2
	;;
esac
