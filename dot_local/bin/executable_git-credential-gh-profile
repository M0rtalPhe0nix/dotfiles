#!/bin/sh
set -eu

[ "${1:-}" = get ] || exit 0

protocol=""
host=""
while IFS='=' read -r key value; do
	case "$key" in
	protocol) protocol="$value" ;;
	host) host="$value" ;;
	esac
done

[ "$protocol" = https ] && [ "$host" = github.com ] || exit 0
profile="$(git config --local --get github.user 2>/dev/null || true)"
[ -n "$profile" ] || exit 0
token="$(gh auth token --hostname github.com --user "$profile")" || exit 1

printf 'username=%s\npassword=%s\n' "$profile" "$token"
