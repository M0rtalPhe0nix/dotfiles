{{- $installPythonLsp := false -}}
{{- if hasKey . "installPythonLsp" -}}
{{-   $installPythonLsp = .installPythonLsp -}}
{{- end -}}
{{- $installTypeScriptLsp := false -}}
{{- if hasKey . "installTypeScriptLsp" -}}
{{-   $installTypeScriptLsp = .installTypeScriptLsp -}}
{{- end -}}
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Read(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.config/zsh/secrets.zsh)"
    ]
  },
  "enabledPlugins": {
    {{- if $installPythonLsp }}
    "pyright-lsp@claude-plugins-official": true{{ if $installTypeScriptLsp }},{{ end }}
    {{- end }}
    {{- if $installTypeScriptLsp }}
    "typescript-lsp@claude-plugins-official": true
    {{- end }}
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-edit-fmt.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
