{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Read(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.config/zsh/secrets.zsh)"
    ]
  }
}
