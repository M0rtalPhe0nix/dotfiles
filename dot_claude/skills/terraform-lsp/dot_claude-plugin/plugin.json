{
  "name": "terraform-lsp",
  "description": "Terraform code intelligence using the mise-managed terraform-ls language server",
  "lspServers": {
    "terraform-ls": {
      "command": "terraform-ls",
      "args": [
        "serve"
      ],
      "extensionToLanguage": {
        ".tf": "terraform",
        ".tfvars": "terraform-vars",
        ".hcl": "hcl"
      }
    }
  }
}
