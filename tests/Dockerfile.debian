FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git zsh \
    && rm -rf /var/lib/apt/lists/* \
    && sh -c "$(curl -fsLS get.chezmoi.io)" -- -b /usr/local/bin

COPY . /source
RUN mkdir -p /tmp/home \
    && printf '[data]\ngitName = "Dotfiles Test"\ngitEmail = "dotfiles@example.invalid"\ninfraTool = "none"\nuseCorporateCA = false\ncorporateCAPath = ""\ninstallClaude = true\n' >/tmp/chezmoi.toml \
    && chezmoi --source /source --destination /tmp/home --config /tmp/chezmoi.toml apply --exclude=scripts \
    && test -f /tmp/home/.zshrc \
    && test -f /tmp/home/.config/Code/User/settings.json \
    && test -x /tmp/home/.local/bin/dotfiles \
    && chezmoi --source /source --config /tmp/chezmoi.toml execute-template </source/.chezmoiscripts/run_once_before_10-packages.sh.tmpl >/tmp/packages.sh \
    && chezmoi --source /source --config /tmp/chezmoi.toml execute-template </source/dot_local/bin/executable_dotfiles.tmpl >/tmp/dotfiles \
    && sh -n /tmp/packages.sh /tmp/dotfiles \
    && test -z "$(chezmoi --source /source --destination /tmp/home --config /tmp/chezmoi.toml diff --exclude=scripts)"
